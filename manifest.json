{
  "manifest_version": 3,
  "name": "ImgtoPrompt",
  "description": "Pinterest 图片分析 + Prompt 生成工具",
  "version": "1.0.0",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": ["contextMenus", "storage"],
  "host_permissions": [
    "https://*.pinterest.com/*",
    "https://pinterest.com/*",
    "https://*.pinimg.com/*",
    "https://pinterest-plugin-server.onrender.com/*",
    "http://localhost:3001/*",
    "http://127.0.0.1:3001/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "ImgtoPrompt",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*.pinterest.com/*", "https://pinterest.com/*"],
      "js": ["utils/constants.js", "utils/dom.js", "utils/imageLocator.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/LOGO.png", "assets/MORE.png"],
      "matches": ["https://*.pinterest.com/*", "https://pinterest.com/*"]
    }
  ]
}
